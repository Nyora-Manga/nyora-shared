# /etc/default/nyora-cluster  — per-node values, read by BOTH the caddy unit and
# the nyora-parser unit (EnvironmentFile). Copy to /etc/default/nyora-cluster on
# each node and fill in that node's view of the cluster. This is the ONLY file
# that differs between nodes; the Caddyfile and all units are identical.

# --- identity -----------------------------------------------------------------
NYORA_NODE_ID=node1                     # node1 | node2 | node3

# --- siblings (PRIVATE VCN IPs of the OTHER two nodes) ------------------------
NYORA_PEER1=10.0.0.12
NYORA_PEER2=10.0.0.13

# --- shared stateful services -------------------------------------------------
# SQLite sync DB lives on node1. On node1 this is 127.0.0.1; on node2/3 it is
# node1's PRIVATE IP so their Caddy forwards sync to the one DB.
NYORA_SYNC_HOST=127.0.0.1
# One shared FlareSolverr (heavy). On its host: 127.0.0.1; elsewhere: its IP.
NYORA_FLARE_HOST=127.0.0.1

# --- helper egress: this node's OWN WARP exit (independent per node) ----------
NYORA_RESIDENTIAL_PROXY=socks5://127.0.0.1:40000
NYORA_FLARESOLVERR=http://127.0.0.1:8191

# --- self-healing DNS (Cloudflare) -------------------------------------------
# A SCOPED, DNS-edit-only token for the nyora.xyz zone. The health timer uses it
# to add/remove THIS node's public IP from the api/sync round-robin records.
CF_API_TOKEN=replace-with-scoped-dns-edit-token
CF_ZONE_ID=086f04xxxxxxxxxxxxxxxxxxxxxxxxxxx
NYORA_PUBLIC_IP=203.0.113.11            # this node's PUBLIC IP
NYORA_LB_RECORDS=api.nyora.xyz          # space-separated records this node joins
